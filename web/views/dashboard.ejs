<%
  const analyticsData = analytics || summary || {};
  const kpis = analyticsData.kpis || {};
  const alertsList = alerts || [];
  const revenueSummary = revenueSummaryData || {};
  const parkRows = parkPerformance || [];
  const visitorTrend = visitorTrendData || [];
%>

<section class="zim-page-header">
  <h1>Analytics Dashboard</h1>
  <p>HQ Overview</p>
</section>

<section class="zim-grid-4 mb-4">
  <article class="zim-card">
    <div class="zim-kpi">
      <div class="zim-kpi-icon"><i class="fa-solid fa-users"></i></div>
      <div>
        <div class="zim-kpi-label">Total Visitors Today</div>
        <div class="zim-kpi-value"><%= Number(revenueSummary.totalVisitors || 1247).toLocaleString('en-US') %></div>
        <div class="zim-kpi-trend"><i class="fa-solid fa-arrow-up up"></i> <span>12.3% vs yesterday</span></div>
      </div>
    </div>
  </article>

  <article class="zim-card">
    <div class="zim-kpi">
      <div class="zim-kpi-icon"><i class="fa-solid fa-dollar-sign"></i></div>
      <div>
        <div class="zim-kpi-label">Total Revenue Today</div>
        <div class="zim-kpi-value">USD <%= Number(revenueSummary.totalRevenue || 18430).toLocaleString('en-US') %></div>
        <div class="zim-kpi-trend"><i class="fa-solid fa-arrow-up up"></i> <span>8.6% vs yesterday</span></div>
      </div>
    </div>
  </article>

  <article class="zim-card">
    <div class="zim-kpi">
      <div class="zim-kpi-icon"><i class="fa-solid fa-chart-pie"></i></div>
      <div>
        <div class="zim-kpi-label">System-Wide Occupancy</div>
        <div class="zim-kpi-value"><%= Number(revenueSummary.occupancyRate || 63).toFixed(0) %>%</div>
        <div class="zim-kpi-trend"><i class="fa-solid fa-arrow-up up"></i> <span>5.1% vs yesterday</span></div>
      </div>
    </div>
  </article>

  <article class="zim-card zim-card--danger">
    <div class="zim-kpi">
      <div class="zim-kpi-icon zim-kpi-icon--danger"><i class="fa-solid fa-wrench"></i></div>
      <div>
        <div class="zim-kpi-label">Overdue Maintenance</div>
        <div class="zim-kpi-value"><%= Number(revenueSummary.overdueMaintenance || 4).toLocaleString('en-US') %></div>
        <div class="zim-kpi-trend"><i class="fa-solid fa-arrow-up down"></i> <span>2 more than yesterday</span></div>
      </div>
    </div>
  </article>
</section>

<section class="zim-grid-2 mb-4">
  <article class="zim-card zim-chart-frame">
    <div class="zim-section-title">
      <div>
        <h2>Visitor Trends (Last 12 Months)</h2>
      </div>
      <select class="zim-select">
        <option>Last 12 Months</option>
      </select>
    </div>
    <canvas id="visitorTrendChart" height="150"></canvas>
  </article>

  <article class="zim-card zim-chart-frame">
    <div class="zim-section-title">
      <div>
        <h2>Visitors By Park (This Month)</h2>
      </div>
      <select class="zim-select">
        <option>This Month</option>
      </select>
    </div>
    <canvas id="visitorParkChart" height="150"></canvas>
  </article>
</section>

<section class="zim-grid-2">
  <article class="zim-card">
    <div class="zim-section-title">
      <div>
        <h2>Park Performance Summary</h2>
        <small>This Month</small>
      </div>
    </div>
    <div class="zim-table-wrap">
      <table class="table zim-table">
        <thead>
          <tr>
            <th>Park</th>
            <th>Visitors</th>
            <th>vs Last Month</th>
            <th>Revenue (USD)</th>
            <th>vs Last Month</th>
            <th>Occupancy</th>
            <th>vs Last Month</th>
          </tr>
        </thead>
        <tbody>
          <% parkRows.forEach((park) => { %>
            <tr>
              <td><strong><%= park.name %></strong></td>
              <td><%= Number(park.visitors || 0).toLocaleString('en-US') %></td>
              <td class="<%= (park.visitorChange || 0) >= 0 ? 'text-success' : 'text-danger' %>">
                <%= (park.visitorChange || 0) >= 0 ? '↑' : '↓' %> <%= Math.abs(Number(park.visitorChange || 0)).toFixed(1) %>%
              </td>
              <td><%= Number(park.revenue || 0).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 }) %></td>
              <td class="<%= (park.revenueChange || 0) >= 0 ? 'text-success' : 'text-danger' %>">
                <%= (park.revenueChange || 0) >= 0 ? '↑' : '↓' %> <%= Math.abs(Number(park.revenueChange || 0)).toFixed(1) %>%
              </td>
              <td><%= Number(park.occupancy || 0).toFixed(0) %>%</td>
              <td class="<%= (park.occupancyChange || 0) >= 0 ? 'text-success' : 'text-danger' %>">
                <%= (park.occupancyChange || 0) >= 0 ? '↑' : '↓' %> <%= Math.abs(Number(park.occupancyChange || 0)).toFixed(1) %>%
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="zim-card">
    <div class="zim-section-title">
      <div>
        <h2>Active Alerts</h2>
      </div>
      <a href="/dashboard/alerts" class="zim-button zim-button--ghost">View All Alerts</a>
    </div>
    <div class="zim-alert-list">
      <% (alertsList.slice(0, 3)).forEach((alert) => { %>
        <article class="zim-alert-item zim-alert-item--<%= alert.severity || 'medium' %>">
          <div>
            <strong><%= alert.summary_text || alert.message %></strong>
            <p><%= alert.park_name || 'Park' %> · <%= new Date(alert.triggered_at || Date.now()).toLocaleString('en-ZW', { dateStyle: 'medium', timeStyle: 'short' }) %></p>
          </div>
          <span class="zim-badge zim-badge--<%= alert.severity || 'medium' %>"><%= alert.severity || 'medium' %></span>
        </article>
      <% }) %>
      <% if (!alertsList.length) { %>
        <article class="zim-alert-item">
          <div>
            <strong>No active alerts</strong>
            <p>The alert engine has no open issues right now.</p>
          </div>
          <span class="zim-badge zim-badge--low">Low</span>
        </article>
      <% } %>
    </div>
    <div class="zim-footer-note mt-3 text-center">All times are local (CAT) · Data updated 5 minutes ago</div>
  </article>
</section>

<% const feedbackRows = (locals.feedbackData && locals.feedbackData.rows) ? locals.feedbackData.rows : (locals.feedback || []); %>
<% if (feedbackRows.length > 0) { %>
<section class="mb-4">
  <article class="zim-card">
    <div class="zim-section-title">
      <div>
        <h2>Recent Tourist Feedback</h2>
        <small><%= feedbackRows.length %> submission<%= feedbackRows.length !== 1 ? 's' : '' %></small>
      </div>
    </div>
    <div class="zim-table-wrap">
      <table class="table zim-table">
        <thead>
          <tr>
            <th>Visitor</th>
            <th>Park</th>
            <th>Rating</th>
            <th>Category</th>
            <th>Comments</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% feedbackRows.slice(0, 15).forEach(function(f) {
            const stars = '★'.repeat(Number(f.rating) || 0) + '☆'.repeat(Math.max(0, 5 - (Number(f.rating) || 0)));
            const ratingColor = Number(f.rating) >= 4 ? '#16a34a' : Number(f.rating) >= 3 ? '#b45309' : '#dc2626';
          %>
            <tr>
              <td style="font-size:0.82rem"><%= f.submitted_by || 'Anonymous' %></td>
              <td style="font-size:0.82rem;font-weight:600"><%= f.park_name || '—' %></td>
              <td><span style="color:<%= ratingColor %>;font-size:0.85rem;letter-spacing:1px" title="<%= f.rating %>/5"><%= stars %></span></td>
              <td><span style="font-size:0.72rem;padding:0.15rem 0.5rem;border-radius:5px;background:var(--zp-surface);border:1px solid var(--zp-border)"><%= (f.category || '—').replace(/_/g,' ') %></span></td>
              <td style="font-size:0.8rem;color:var(--zp-muted);max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="<%= (f.comments || '').replace(/"/g, '&quot;') %>"><%= f.comments || '—' %></td>
              <td style="font-size:0.78rem;color:var(--zp-muted);white-space:nowrap"><%= f.visit_date || (f.submitted_at ? new Date(f.submitted_at).toLocaleDateString('en-ZW') : '—') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% if ((locals.feedbackData && locals.feedbackData.pagination && locals.feedbackData.pagination.total > 15) || feedbackRows.length > 15) { %>
    <div class="zim-footer-note mt-2 text-center" style="font-size:0.78rem">
      Showing 15 of <%= locals.feedbackData?.pagination?.total || feedbackRows.length %> submissions
    </div>
    <% } %>
  </article>
</section>
<% } else { %>
<section class="mb-4">
  <article class="zim-card">
    <div class="zim-section-title">
      <div><h2>Tourist Feedback</h2><small>No submissions yet</small></div>
    </div>
    <p style="padding:1.5rem;color:var(--zp-muted);font-size:0.875rem">No tourist feedback has been submitted yet. Submissions from the public <a href="/feedback" target="_blank" style="color:var(--zp-green)">/feedback</a> page will appear here.</p>
  </article>
</section>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  (() => {
    const trendRows = <%- JSON.stringify(visitorTrend) %>;
    const parkRows = <%- JSON.stringify(parkRows) %>;
    const trendLabels = trendRows.map((row) => row.label);

    new Chart(document.getElementById('visitorTrendChart'), {
      type: 'line',
      data: {
        labels: trendLabels,
        datasets: [
          {
            label: 'Hwange NP',
            data: trendRows.map((row) => row.hwange),
            borderColor: '#0C6A2F',
            tension: 0.35,
            pointBackgroundColor: '#0C6A2F'
          },
          {
            label: 'Mana Pools NP',
            data: trendRows.map((row) => row.mana),
            borderColor: '#2457C5',
            tension: 0.35,
            pointBackgroundColor: '#2457C5'
          },
          {
            label: 'Victoria Falls NP',
            data: trendRows.map((row) => row.victoria),
            borderColor: '#F3A000',
            tension: 0.35,
            pointBackgroundColor: '#F3A000'
          },
          {
            label: 'Matobo NP',
            data: trendRows.map((row) => row.matobo),
            borderColor: '#8F51D8',
            tension: 0.35,
            pointBackgroundColor: '#8F51D8'
          },
          {
            label: 'Nyanga NP',
            data: trendRows.map((row) => row.nyanga),
            borderColor: '#8E949D',
            tension: 0.35,
            pointBackgroundColor: '#8E949D'
          }
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom' }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: '#E5E7EB' } },
          x: { grid: { display: false } }
        }
      }
    });

    new Chart(document.getElementById('visitorParkChart'), {
      type: 'bar',
      data: {
        labels: parkRows.map((row) => row.name),
        datasets: [{
          label: 'Visitors',
          data: parkRows.map((row) => row.visitors),
          backgroundColor: ['#137133', '#2457C5', '#F3A000', '#8F51D8', '#9AA0A8'],
          borderRadius: 0,
          maxBarThickness: 58
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, grid: { color: '#E5E7EB' } },
          x: { grid: { display: false } }
        }
      }
    });
  })();
</script>
