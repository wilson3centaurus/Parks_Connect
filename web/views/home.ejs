<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Parks Connect | Zimbabwe National Parks</title>
  <link rel="stylesheet" href="/public/css/auth.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0a1628; color: #fff; min-height: 100vh; }

    /* Nav */
    .home-nav { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .nav-brand { display: flex; align-items: center; gap: 0.75rem; }
    .nav-brand img { height: 36px; width: 36px; object-fit: contain; }
    .nav-brand-text h1 { font-size: 1.1rem; font-weight: 700; color: #fff; }
    .nav-brand-text p { font-size: 0.7rem; color: rgba(255,255,255,0.5); }
    .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
    .btn-nav-ghost { padding: 0.5rem 1.25rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: rgba(255,255,255,0.8); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: all 0.15s; }
    .btn-nav-ghost:hover { border-color: rgba(255,255,255,0.5); color: #fff; background: rgba(255,255,255,0.06); }
    .btn-nav-primary { padding: 0.5rem 1.25rem; border-radius: 8px; background: #22c55e; color: #fff; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: background 0.15s; }
    .btn-nav-primary:hover { background: #16a34a; }

    /* Hero */
    .hero { text-align: center; padding: 5rem 2rem 3rem; max-width: 700px; margin: 0 auto; }
    .hero-badge { display: inline-block; padding: 0.3rem 0.9rem; background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); border-radius: 20px; font-size: 0.75rem; font-weight: 600; color: #22c55e; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .hero h2 { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; line-height: 1.15; color: #fff; margin-bottom: 1.25rem; }
    .hero h2 span { color: #22c55e; }
    .hero p { font-size: 1.05rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin-bottom: 2.5rem; }
    .hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
    .btn-hero-primary { padding: 0.85rem 2rem; border-radius: 10px; background: #22c55e; color: #fff; text-decoration: none; font-size: 0.95rem; font-weight: 700; transition: background 0.15s; }
    .btn-hero-primary:hover { background: #16a34a; }
    .btn-hero-outline { padding: 0.85rem 2rem; border-radius: 10px; border: 1.5px solid rgba(255,255,255,0.25); color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.95rem; font-weight: 600; transition: all 0.15s; }
    .btn-hero-outline:hover { border-color: rgba(255,255,255,0.5); color: #fff; background: rgba(255,255,255,0.06); }

    /* Stats bar */
    .stats-bar { display: flex; flex-wrap: wrap; justify-content: center; gap: 0; border-top: 1px solid rgba(255,255,255,0.07); border-bottom: 1px solid rgba(255,255,255,0.07); margin: 3rem 0; }
    .stat { flex: 1; min-width: 140px; padding: 1.5rem 1rem; text-align: center; border-right: 1px solid rgba(255,255,255,0.07); }
    .stat:last-child { border-right: none; }
    .stat-value { font-size: 1.75rem; font-weight: 800; color: #22c55e; display: block; }
    .stat-label { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-top: 0.2rem; text-transform: uppercase; letter-spacing: 0.05em; }

    /* Parks grid */
    .section { max-width: 1100px; margin: 0 auto; padding: 0 2rem 4rem; }
    .section-title { font-size: 1.4rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
    .section-sub { font-size: 0.875rem; color: rgba(255,255,255,0.45); margin-bottom: 2rem; }
    .parks-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
    .park-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 1.5rem; transition: border-color 0.15s, background 0.15s; }
    .park-card:hover { border-color: rgba(34,197,94,0.3); background: rgba(34,197,94,0.04); }
    .park-card-badge { display: inline-block; padding: 0.2rem 0.6rem; background: rgba(34,197,94,0.15); border-radius: 6px; font-size: 0.7rem; font-weight: 700; color: #22c55e; text-transform: uppercase; margin-bottom: 0.85rem; }
    .park-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
    .park-card p { font-size: 0.82rem; color: rgba(255,255,255,0.45); line-height: 1.6; }

    /* Feedback CTA */
    .feedback-banner { max-width: 1100px; margin: 0 auto 4rem; padding: 0 2rem; }
    .feedback-card { background: linear-gradient(135deg, rgba(34,197,94,0.12) 0%, rgba(16,185,129,0.06) 100%); border: 1px solid rgba(34,197,94,0.2); border-radius: 16px; padding: 2.5rem 2rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.5rem; }
    .feedback-card-text h3 { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 0.4rem; }
    .feedback-card-text p { font-size: 0.875rem; color: rgba(255,255,255,0.5); }
    .btn-feedback { padding: 0.75rem 1.75rem; border-radius: 10px; background: #22c55e; color: #fff; text-decoration: none; font-size: 0.9rem; font-weight: 700; white-space: nowrap; transition: background 0.15s; }
    .btn-feedback:hover { background: #16a34a; }

    /* Footer */
    .home-footer { text-align: center; padding: 2rem; border-top: 1px solid rgba(255,255,255,0.06); font-size: 0.78rem; color: rgba(255,255,255,0.25); }
    .home-footer a { color: rgba(255,255,255,0.35); text-decoration: none; }
    .home-footer a:hover { color: rgba(255,255,255,0.6); }
  </style>
</head>
<body>

  <nav class="home-nav">
    <div class="nav-brand">
      <img src="/public/images/logo.png" alt="ZimParks">
      <div class="nav-brand-text">
        <h1>Parks Connect</h1>
        <p>Zimbabwe National Parks Authority</p>
      </div>
    </div>
    <div class="nav-actions">
      <a href="/feedback" class="btn-nav-ghost">Submit Feedback</a>
      <a href="/login" class="btn-nav-primary">Staff Login</a>
    </div>
  </nav>

  <div class="hero">
    <div class="hero-badge">Zimbabwe National Parks</div>
    <h2>Protecting Zimbabwe's<br><span>Natural Heritage</span></h2>
    <p>Parks Connect is the operational platform for Zimbabwe's protected areas — connecting rangers, tourism operators, and administrators to monitor, protect, and manage national parks in real time.</p>
    <div class="hero-cta">
      <a href="/feedback" class="btn-hero-primary">Share Your Experience</a>
      <a href="/login" class="btn-hero-outline">Staff Portal Login</a>
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat"><span class="stat-value">11</span><span class="stat-label">National Parks</span></div>
    <div class="stat"><span class="stat-value">5M+</span><span class="stat-label">Hectares Protected</span></div>
    <div class="stat"><span class="stat-value">500+</span><span class="stat-label">Wildlife Species</span></div>
    <div class="stat"><span class="stat-value">Real-time</span><span class="stat-label">Monitoring</span></div>
  </div>

  <div class="section">
    <h2 class="section-title">National Parks</h2>
    <p class="section-sub">Zimbabwe's most iconic protected areas, managed through Parks Connect</p>
    <div class="parks-grid">
      <% if (parks && parks.length > 0) { %>
        <% parks.forEach(function(park) { %>
          <div class="park-card">
            <div class="park-card-badge"><%= park.code || 'PARK' %></div>
            <h3><%= park.name %></h3>
            <p><%= park.region ? park.region + ' Region' : 'Zimbabwe National Park' %></p>
          </div>
        <% }); %>
      <% } else { %>
        <div class="park-card">
          <div class="park-card-badge">HNP</div>
          <h3>Hwange National Park</h3>
          <p>Zimbabwe's largest national park, home to more than 100 mammal and 400 bird species.</p>
        </div>
        <div class="park-card">
          <div class="park-card-badge">VF</div>
          <h3>Victoria Falls National Park</h3>
          <p>UNESCO World Heritage Site surrounding one of the world's largest waterfalls.</p>
        </div>
        <div class="park-card">
          <div class="park-card-badge">MP</div>
          <h3>Mana Pools National Park</h3>
          <p>UNESCO World Heritage Site on the Zambezi floodplains, known for walking safaris.</p>
        </div>
        <div class="park-card">
          <div class="park-card-badge">GP</div>
          <h3>Gonarezhou National Park</h3>
          <p>Remote wilderness in the south-east, home to large elephant herds and rare birds.</p>
        </div>
        <div class="park-card">
          <div class="park-card-badge">MNP</div>
          <h3>Matobo National Park</h3>
          <p>Ancient granite hills sheltering cave paintings, white rhinos, and diverse wildlife.</p>
        </div>
        <div class="park-card">
          <div class="park-card-badge">NYA</div>
          <h3>Nyanga National Park</h3>
          <p>Zimbabwe's highest mountains with waterfalls, forests, and trout streams.</p>
        </div>
      <% } %>
    </div>
  </div>

  <div class="feedback-banner">
    <div class="feedback-card">
      <div class="feedback-card-text">
        <h3>Visited a Zimbabwe national park?</h3>
        <p>Share your experience and help us improve conservation and visitor services across all parks.</p>
      </div>
      <a href="/feedback" class="btn-feedback">Submit Feedback</a>
    </div>
  </div>

  <footer class="home-footer">
    <p>&copy; <%= new Date().getFullYear() %> Zimbabwe Parks and Wildlife Management Authority &mdash; <a href="/login">Staff Login</a></p>
  </footer>

</body>
</html>
