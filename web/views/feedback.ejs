<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ZimParks | Visitor Feedback</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/styles.css">
</head>
<body>
  <main class="zim-public-shell">
    <div class="zim-public-wrap">
      <div class="zim-public-header">
        <img src="/public/images/logo.png" alt="ZimParks logo">
        <div>
          <h1 class="m-0">ZIMPARKS</h1>
          <p class="m-0">WILDLIFE · HERITAGE · HOSPITALITY</p>
        </div>
      </div>

      <div class="zim-public-grid">
        <section class="zim-public-hero">
          <span class="zim-badge" style="background:rgba(255,255,255,0.12);color:#fff;">ZimParks visitor voice</span>
          <h2 class="mt-3 mb-3" style="font-size:clamp(2rem,4vw,3.25rem); line-height:1.02;">Share what happened in the park while the details are still fresh.</h2>
          <p style="color:rgba(255,255,255,0.84); max-width:34rem;">Your response feeds the same operations platform used by park managers, environmental officers, and tourism teams. Reports submitted here appear alongside mobile and email feedback.</p>
          <div class="zim-card mt-4" style="background:rgba(255,255,255,0.08); border-color:rgba(255,255,255,0.18); color:#fff;">
            <h3 class="m-0 mb-3" style="font-size:18px;">What we review</h3>
            <ul class="m-0 ps-3" style="color:rgba(255,255,255,0.84);">
              <li>Wildlife sightings and interpretation quality</li>
              <li>Facilities, water, sanitation, and accommodation issues</li>
              <li>Safety, staff support, and general visitor experience</li>
            </ul>
          </div>
        </section>

        <section class="zim-public-card">
          <div class="mb-3">
            <h2 class="m-0" style="font-size:28px;">Tourist Feedback</h2>
            <p class="mb-0 text-muted">All fields below are reviewed by the management team.</p>
          </div>

          <% if (success) { %><div class="notice success"><%= success %></div><% } %>
          <% if (errors.form) { %><div class="notice error"><%= errors.form %></div><% } %>

          <form method="POST" action="/feedback" novalidate class="zim-form-grid">
            <div class="zim-field zim-field--full">
              <label for="submitted_by">Your name</label>
              <input id="submitted_by" name="submitted_by" type="text" value="<%= values.submitted_by || '' %>" placeholder="Optional">
            </div>
            <div class="zim-field">
              <label for="park_id">Park selection</label>
              <select id="park_id" name="park_id" required>
                <option value="">Select a park</option>
                <% (parks || []).forEach((park) => { %>
                  <option value="<%= park.id %>" <%= String(values.park_id || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
                <% }) %>
              </select>
              <% if (errors.park_id) { %><div class="field-error"><%= errors.park_id %></div><% } %>
            </div>
            <div class="zim-field">
              <label for="visit_date">Visit date</label>
              <input id="visit_date" name="visit_date" type="date" value="<%= values.visit_date || '' %>" required>
              <% if (errors.visit_date) { %><div class="field-error"><%= errors.visit_date %></div><% } %>
            </div>
            <div class="zim-field">
              <label for="rating">Rating</label>
              <select id="rating" name="rating" required>
                <option value="">Choose</option>
                <% [1,2,3,4,5].forEach((rating) => { %>
                  <option value="<%= rating %>" <%= String(values.rating || '') === String(rating) ? 'selected' : '' %>><%= rating %> / 5</option>
                <% }) %>
              </select>
              <% if (errors.rating) { %><div class="field-error"><%= errors.rating %></div><% } %>
            </div>
            <div class="zim-field">
              <label for="category">Category</label>
              <select id="category" name="category" required>
                <% ['wildlife','facilities','safety','staff','general'].forEach((category) => { %>
                  <option value="<%= category %>" <%= String(values.category || 'general') === category ? 'selected' : '' %>><%= category.charAt(0).toUpperCase() + category.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <div class="zim-field zim-field--full">
              <label for="comments">Comment</label>
              <textarea id="comments" name="comments" placeholder="Describe what happened, where it happened, and how it affected your visit." required><%= values.comments || '' %></textarea>
              <% if (errors.comments) { %><div class="field-error"><%= errors.comments %></div><% } %>
            </div>
            <div class="zim-field zim-field--full">
              <button type="submit" class="zim-button w-100"><i class="fa-solid fa-paper-plane"></i> Submit feedback</button>
            </div>
          </form>
        </section>
      </div>
    </div>
  </main>
</body>
</html>
