<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>You're Offline — Parks Connect</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1D9E75">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #0a1628;
      color: #fff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      text-align: center;
    }

    .offline-icon {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: rgba(29,158,117,0.12);
      border: 1.5px solid rgba(29,158,117,0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.75rem;
      font-size: 2.2rem;
    }

    .logo-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 3rem;
      opacity: 0.7;
    }
    .logo-row img { height: 32px; width: 32px; object-fit: contain; }
    .logo-row span { font-size: 0.9rem; font-weight: 700; color: rgba(255,255,255,0.8); }

    h1 { font-size: 1.6rem; font-weight: 800; margin-bottom: 0.6rem; }
    p  { font-size: 0.9rem; color: rgba(255,255,255,0.5); line-height: 1.65; max-width: 320px; margin: 0 auto 2rem; }

    .offline-tips {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      margin-bottom: 2.5rem;
      width: 100%;
      max-width: 320px;
    }
    .offline-tip {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 10px;
      padding: 0.7rem 1rem;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.6);
      text-align: left;
    }
    .offline-tip i { color: #1D9E75; font-size: 0.9rem; flex-shrink: 0; }

    .btn-retry {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.75rem;
      background: #1D9E75;
      color: #fff;
      border: none;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.15s;
      text-decoration: none;
    }
    .btn-retry:hover { background: #16a34a; }

    .offline-footer {
      margin-top: 3rem;
      font-size: 0.72rem;
      color: rgba(255,255,255,0.2);
    }
  </style>
</head>
<body>

  <div class="logo-row">
    <img src="/public/images/logo.png" alt="ZimParks">
    <span>Parks Connect</span>
  </div>

  <div class="offline-icon">🌿</div>

  <h1>You're offline</h1>
  <p>No internet connection detected. Some content may be available from your last visit.</p>

  <div class="offline-tips">
    <div class="offline-tip">
      <i class="fa-solid fa-map"></i>
      Previously visited park pages may still be available below.
    </div>
    <div class="offline-tip">
      <i class="fa-solid fa-wifi"></i>
      Connect to Wi-Fi or mobile data and tap Retry.
    </div>
  </div>

  <button class="btn-retry" onclick="window.location.reload()">
    ↻ &nbsp;Retry
  </button>

  <div class="offline-footer">
    Zimbabwe Parks &amp; Wildlife Management Authority
  </div>

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet">
</body>
</html>
