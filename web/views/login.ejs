<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign in | Parks Connect</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      background:
        radial-gradient(ellipse at top left, rgba(198,162,90,0.14) 0%, transparent 50%),
        radial-gradient(ellipse at bottom right, rgba(31,111,86,0.18) 0%, transparent 50%),
        linear-gradient(135deg, #031611 0%, #06211a 40%, #0d3b2f 100%);
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    .card {
      position: relative;
      width: 100%;
      max-width: 390px;
      background: rgba(247,251,248,0.97);
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.28);
      box-shadow: 0 32px 80px rgba(3,22,17,0.4), 0 8px 24px rgba(3,22,17,0.2);
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      inset: 0 0 auto;
      height: 3px;
      background: linear-gradient(90deg, #c6a25a, #2d8d6b);
    }

    .card-body { padding: 2rem 2rem 1.5rem; }

    /* Brand — centered */
    .brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.75rem;
      text-align: center;
    }
    .brand-logo {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: #0a2e24;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 6px;
      box-shadow: 0 4px 14px rgba(3,22,17,0.25);
    }
    .brand-logo img { width: 100%; height: 100%; object-fit: contain; }
    .brand-text strong { display: block; font-size: 0.95rem; font-weight: 700; color: #102019; letter-spacing: -0.01em; }
    .brand-text span { font-size: 0.72rem; color: #7a9488; }

    /* Heading — centered */
    .card-heading {
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .card-heading h1 { font-size: 1.3rem; font-weight: 700; color: #102019; letter-spacing: -0.02em; margin-bottom: 0.25rem; }
    .card-heading p { font-size: 0.8rem; color: #7a9488; line-height: 1.5; }

    /* Fields */
    .field { margin-bottom: 0.85rem; }
    label { display: block; font-size: 0.74rem; font-weight: 600; color: #3d5147; margin-bottom: 0.3rem; letter-spacing: 0.01em; }
    input[type="email"],
    input[type="password"],
    input[type="text"] {
      width: 100%;
      padding: 0.6rem 0.85rem;
      border: 1px solid rgba(16,32,25,0.13);
      border-radius: 10px;
      background: #fff;
      color: #102019;
      font-size: 0.875rem;
      font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
      box-shadow: inset 0 1px 2px rgba(16,32,25,0.04);
    }
    input::placeholder { color: #aabdb5; }
    input:focus {
      outline: none;
      border-color: rgba(20,84,66,0.4);
      box-shadow: 0 0 0 3px rgba(31,111,86,0.1), inset 0 1px 2px rgba(16,32,25,0.04);
    }

    /* Password */
    .pw-wrap { position: relative; }
    .pw-wrap input { padding-right: 3.5rem; }
    .pw-toggle {
      position: absolute;
      right: 0.5rem;
      top: 50%;
      transform: translateY(-50%);
      padding: 0.2rem 0.5rem;
      border: 1px solid rgba(16,32,25,0.1);
      border-radius: 6px;
      background: rgba(16,32,25,0.04);
      color: #5b6f66;
      font-size: 0.68rem;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
    }
    .pw-toggle:hover { background: rgba(16,32,25,0.09); }

    /* Submit */
    .btn-submit {
      width: 100%;
      padding: 0.65rem 1rem;
      margin-top: 0.35rem;
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, #145442, #1f6f56);
      color: #fff;
      font-size: 0.875rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(20,84,66,0.3);
      transition: opacity 0.15s, transform 0.12s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
    }
    .btn-submit:hover:not(:disabled) { opacity: 0.92; transform: translateY(-1px); }
    .btn-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    /* Spinner */
    .spinner {
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,0.35);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      display: none;
    }
    .btn-submit.loading .spinner { display: block; }
    .btn-submit.loading .btn-label { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Footer */
    .card-footer {
      border-top: 1px solid rgba(16,32,25,0.07);
      padding: 0.85rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-footer p { font-size: 0.71rem; color: #9ab0a6; }
    .card-footer a {
      font-size: 0.71rem;
      color: #1f6f56;
      font-weight: 600;
      text-decoration: none;
    }
    .card-footer a:hover { text-decoration: underline; }

    /* SweetAlert theme overrides */
    .swal2-popup { border-radius: 16px !important; font-family: inherit !important; }
    .swal2-confirm { border-radius: 8px !important; font-weight: 700 !important; padding: 0.5rem 1.5rem !important; }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-body">

      <div class="brand">
        <div class="brand-logo">
          <img src="/public/images/logo.png" alt="ZimParks">
        </div>
        <div class="brand-text">
          <strong>Parks Connect</strong>
          <span>Zimbabwe National Parks</span>
        </div>
      </div>

      <div class="card-heading">
        <h1>Sign in</h1>
        <p>Enter your staff credentials to continue.</p>
      </div>

      <form id="loginForm" novalidate>
        <div class="field">
          <label for="email">Email address</label>
          <input id="email" name="email" type="email" placeholder="you@zimparks.gov.zw" autocomplete="username" required autofocus>
        </div>
        <div class="field">
          <label for="password">Password</label>
          <div class="pw-wrap">
            <input id="password" name="password" type="password" placeholder="••••••••" minlength="6" maxlength="128" autocomplete="current-password" required>
            <button type="button" class="pw-toggle" id="pwToggle">Show</button>
          </div>
        </div>
        <button type="submit" class="btn-submit" id="submitBtn">
          <span class="spinner"></span>
          <span class="btn-label">Sign in</span>
        </button>
      </form>

    </div>

    <div class="card-footer">
      <p>Need access? Contact your administrator.</p>
      <a href="/">&larr; Back to home</a>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    // Password toggle
    var pwToggle = document.getElementById('pwToggle');
    var pwInput = document.getElementById('password');
    pwToggle.addEventListener('click', function () {
      var show = pwInput.type === 'password';
      pwInput.type = show ? 'text' : 'password';
      pwToggle.textContent = show ? 'Hide' : 'Show';
    });

    // SweetAlert theme
    var Toast = Swal.mixin({
      toast: true,
      position: 'top-end',
      showConfirmButton: false,
      timer: 3000,
      timerProgressBar: true
    });

    function setLoading(on) {
      var btn = document.getElementById('submitBtn');
      btn.disabled = on;
      btn.classList.toggle('loading', on);
    }

    document.getElementById('loginForm').addEventListener('submit', async function (e) {
      e.preventDefault();

      var email = document.getElementById('email').value.trim();
      var password = document.getElementById('password').value;

      if (!email) {
        return Swal.fire({ icon: 'warning', title: 'Email required', text: 'Please enter your email address.', confirmButtonColor: '#145442' });
      }
      if (!password) {
        return Swal.fire({ icon: 'warning', title: 'Password required', text: 'Please enter your password.', confirmButtonColor: '#145442' });
      }

      setLoading(true);

      try {
        var resp = await fetch('/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ email: email, password: password })
        });

        var data = await resp.json().catch(function () { return {}; });

        if (resp.ok && data.redirect) {
          Toast.fire({ icon: 'success', title: 'Signed in successfully' });
          setTimeout(function () { window.location.href = data.redirect; }, 800);
          return;
        }

        setLoading(false);

        if (resp.status === 401) {
          Swal.fire({
            icon: 'error',
            title: 'Incorrect credentials',
            text: 'The email or password you entered is wrong. Please try again.',
            confirmButtonColor: '#145442',
            confirmButtonText: 'Try again'
          });
        } else if (resp.status === 403) {
          Swal.fire({
            icon: 'warning',
            title: 'Access restricted',
            text: data.message || 'This account type cannot access the web portal. Use the mobile app instead.',
            confirmButtonColor: '#145442'
          });
        } else if (resp.status >= 500) {
          Swal.fire({
            icon: 'error',
            title: 'Server error',
            text: 'The server ran into an issue. Please try again in a moment.',
            confirmButtonColor: '#145442'
          });
        } else {
          Swal.fire({
            icon: 'error',
            title: 'Login failed',
            text: data.message || 'Something went wrong. Please try again.',
            confirmButtonColor: '#145442'
          });
        }

      } catch (err) {
        setLoading(false);
        Swal.fire({
          icon: 'error',
          title: 'Cannot reach server',
          text: 'Unable to connect to Parks Connect. Check your internet connection and try again.',
          confirmButtonColor: '#145442'
        });
      }
    });

    <% if (typeof error !== 'undefined' && error) { %>
    // Show server-side error (e.g. from redirect with error param)
    Swal.fire({ icon: 'error', title: 'Login failed', text: '<%= error %>', confirmButtonColor: '#145442' });
    <% } %>
    <% if (typeof success !== 'undefined' && success) { %>
    Toast.fire({ icon: 'success', title: '<%= success %>' });
    <% } %>
  </script>
</body>
</html>
