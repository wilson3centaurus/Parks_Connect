{
  "name": "zimparks-platform",
  "version": "1.0.0",
  "description": "Legacy monolith shell for Parks Connect. Active deploys live in backend/ and web/.",
  "main": "app.js",
  "scripts": {
    "start": "npm --prefix web run start",
    "dev": "npm --prefix web run dev",
    "dev:web": "npm --prefix web run dev",
    "dev:backend": "npm --prefix backend run dev",
    "start:legacy": "node app.js",
    "dev:legacy": "nodemon app.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "multer": "^2.0.2",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
