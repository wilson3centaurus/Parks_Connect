<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Tourism charts</h2>
      <p>Feedback, visitor movement, alerts, and wildlife visibility across your park portfolio.</p>
    </div>
  </div>
  <div class="chart-grid">
    <article class="card chart-card">
      <div class="section-header"><div><h2>Feedback ratings distribution</h2><p>Service sentiment from recent submissions.</p></div></div>
      <canvas id="feedbackRatingsChart"></canvas>
    </article>
    <article class="card chart-card">
      <div class="section-header"><div><h2>Visitor trends per park</h2><p>Traffic pattern and park utilization trend.</p></div></div>
      <canvas id="visitorTrendsChart"></canvas>
    </article>
    <article class="card chart-card">
      <div class="section-header"><div><h2>Alerts by type and severity</h2><p>Operational events affecting visitor experience.</p></div></div>
      <canvas id="alertsByTypeChart"></canvas>
    </article>
    <article class="card chart-card">
      <div class="section-header"><div><h2>Wildlife sightings by species</h2><p>Top wildlife activity relevant to tourism visibility.</p></div></div>
      <canvas id="wildlifeBySpeciesChart"></canvas>
    </article>
  </div>
</section>

<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Quick links</h2>
      <p>Keep feedback and visitor reporting within reach.</p>
    </div>
  </div>
  <div class="link-grid">
    <% quickLinks.forEach((link) => { %>
      <a class="link-card" href="<%= link.href %>"><%= link.label %></a>
    <% }) %>
  </div>
</section>

<section class="page-grid two-column">
  <section class="card stack">
    <div class="section-header">
      <div>
        <h2>Update visitor counts</h2>
        <p>Post current park occupancy and keep analytics fresh. Pending feedback: <strong><%= pendingFeedbackCount %></strong> · Average rating: <strong><%= Number(averageRatingThisMonth || 0).toFixed(2) %></strong> · Total visitors this month: <strong><%= totalVisitorsThisMonth %></strong></p>
      </div>
    </div>
    <% if (visitorCounts.length) { %>
      <div class="stack">
        <% visitorCounts.forEach((park) => { %>
          <form method="POST" action="/admin/parks/<%= park.id %>/visitors" class="inline-form wrap">
            <div class="inline-block wide">
              <strong><%= park.name %></strong>
              <div class="muted-copy">Capacity <%= park.capacity %> · Current <%= park.current_visitors %></div>
            </div>
            <input type="number" name="visitors" min="0" value="<%= park.current_visitors %>" required>
            <input type="date" name="logDate" value="<%= formData.logDate || '' %>">
            <button type="submit" class="btn btn-primary">Save</button>
          </form>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">No assigned parks available for visitor updates.</div>
    <% } %>
  </section>

  <section class="card stack">
    <div class="section-header">
      <div>
        <h2>Recent feedback</h2>
        <p>Latest tourist input for your park portfolio.</p>
      </div>
      <a href="/feedback/manage" class="btn btn-secondary">Manage feedback</a>
    </div>
    <% if (recentFeedback.length) { %>
      <div class="stack tight">
        <% recentFeedback.forEach((item) => { %>
          <div class="list-row align-start">
            <div>
              <strong><%= item.visitor_name %></strong>
              <div class="muted-copy"><%= item.park_name %> · <%= item.category %> · <%= formatDate(item.submitted_at) %></div>
              <div><%= item.message %></div>
            </div>
            <span class="badge neutral"><%= item.rating %>/5</span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state">No feedback records available.</div>
    <% } %>
  </section>
</section>

<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Visitor count per park</h2>
      <p>Current utilization snapshot across <strong><%= visitorCounts.length %></strong> park entries.</p>
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Park</th>
          <th>Region</th>
          <th>Capacity</th>
          <th>Current Visitors</th>
          <th>Occupancy</th>
        </tr>
      </thead>
      <tbody>
        <% if (visitorCounts.length) { %>
          <% visitorCounts.forEach((park) => { %>
            <tr>
              <td><strong><%= park.name %></strong></td>
              <td><%= park.region %></td>
              <td><%= park.capacity %></td>
              <td><%= park.current_visitors %></td>
              <td><span class="badge <%= park.occupancy_percent >= 90 ? 'warning' : 'success' %>"><%= Number(park.occupancy_percent || 0).toFixed(2) %>%</span></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="empty-state">No visitor data available.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
