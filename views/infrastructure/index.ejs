<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Infrastructure reports</h2>
      <p>Monitor roads, gates, buildings, and other critical assets.</p>
    </div>
    <% if (user.role !== 'analyst') { %><a href="/infrastructure/new" class="btn btn-primary">Report status</a><% } %>
  </div>
  <form method="GET" action="/infrastructure" class="form-grid four-col compact">
    <select name="parkId">
      <option value="">All parks</option>
      <% parks.forEach((park) => { %>
        <option value="<%= park.id %>" <%= String(filters.parkId || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
      <% }) %>
    </select>
    <select name="type">
      <option value="">All types</option>
      <% ['road', 'fence', 'gate', 'building', 'water_point', 'communications', 'vehicle'].forEach((item) => { %>
        <option value="<%= item %>" <%= filters.type === item ? 'selected' : '' %>><%= item %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All status</option>
      <% ['operational', 'needs_maintenance', 'failed'].forEach((state) => { %>
        <option value="<%= state %>" <%= filters.status === state ? 'selected' : '' %>><%= state %></option>
      <% }) %>
    </select>
    <select name="limit">
      <% [10, 25, 50].forEach((item) => { %>
        <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary">Apply</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Park</th>
          <th>Name</th>
          <th>Type</th>
          <th>Status</th>
          <th>Last Inspected</th>
          <th>Reported By</th>
        </tr>
      </thead>
      <tbody>
        <% if (reports.length) { %>
          <% reports.forEach((item) => { %>
            <tr>
              <td><%= item.park_name %></td>
              <td><strong><%= item.name %></strong></td>
              <td><%= item.type %></td>
              <td><span class="badge <%= item.status === 'failed' ? 'error' : item.status === 'needs_maintenance' ? 'warning' : 'success' %>"><%= item.status %></span></td>
              <td><%= item.last_inspected || '—' %></td>
              <td><%= item.reported_by_name %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="empty-state">No infrastructure reports found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
