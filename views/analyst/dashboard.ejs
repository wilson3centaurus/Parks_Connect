<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Quick links</h2>
      <p>Open the modules behind the analytics view.</p>
    </div>
  </div>
  <div class="link-grid">
    <% quickLinks.forEach((link) => { %>
      <a class="link-card" href="<%= link.href %>"><%= link.label %></a>
    <% }) %>
  </div>
</section>

<section class="chart-grid">
  <article class="card chart-card">
    <div class="section-header"><div><h2>Wildlife sightings by species</h2><p>Top 10 species volume.</p></div></div>
    <canvas id="wildlifeBySpeciesChart"></canvas>
  </article>
  <article class="card chart-card">
    <div class="section-header"><div><h2>Environmental readings over time</h2><p>30-day trend by reading type.</p></div></div>
    <canvas id="readingsOverTimeChart"></canvas>
  </article>
  <article class="card chart-card">
    <div class="section-header"><div><h2>Feedback ratings distribution</h2><p>Scores from 1 to 5.</p></div></div>
    <canvas id="feedbackRatingsChart"></canvas>
  </article>
  <article class="card chart-card">
    <div class="section-header"><div><h2>Alerts by type and severity</h2><p>Operational alert volumes.</p></div></div>
    <canvas id="alertsByTypeChart"></canvas>
  </article>
  <article class="card chart-card">
    <div class="section-header"><div><h2>Visitor trends per park</h2><p>Last 30 days.</p></div></div>
    <canvas id="visitorTrendsChart"></canvas>
  </article>
  <article class="card chart-card">
    <div class="section-header"><div><h2>Infrastructure status breakdown</h2><p>Current reported state.</p></div></div>
    <canvas id="infrastructureStatusChart"></canvas>
  </article>
</section>
