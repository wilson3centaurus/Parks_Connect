<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Wildlife sightings</h2>
      <p>Paginated wildlife records across accessible parks.</p>
    </div>
    <% if (user.role !== 'analyst') { %><a href="/wildlife/new" class="btn btn-primary">Add sighting</a><% } %>
  </div>
  <form method="GET" action="/wildlife" class="form-grid four-col compact">
    <select name="parkId">
      <option value="">All parks</option>
      <% parks.forEach((park) => { %>
        <option value="<%= park.id %>" <%= String(filters.parkId || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
      <% }) %>
    </select>
    <input type="text" name="species" value="<%= filters.species || '' %>" placeholder="Search species">
    <select name="limit">
      <% [10, 25, 50].forEach((item) => { %>
        <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary">Apply</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Park</th>
          <th>Species</th>
          <th>Category</th>
          <th>Count</th>
          <th>Recorded By</th>
          <th>Photo</th>
        </tr>
      </thead>
      <tbody>
        <% if (sightings.length) { %>
          <% sightings.forEach((item) => { %>
            <tr>
              <td><%= formatDate(item.sighting_date) %></td>
              <td><%= item.park_name %></td>
              <td><strong><%= item.common_name %></strong><div class="muted-copy"><%= item.species_name %></div></td>
              <td><span class="badge neutral"><%= item.category %></span></td>
              <td><%= item.count %></td>
              <td><%= item.recorded_by_name %></td>
              <td>
                <% if (item.photo) { %>
                  <a href="<%= item.photo %>" target="_blank" rel="noreferrer">View photo</a>
                <% } else { %>—<% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" class="empty-state">No wildlife sightings found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
