<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Log filters</h2>
      <p>Filter the last 50 records per page and export the current selection.</p>
    </div>
    <a class="btn btn-secondary" href="/admin/logs/export?<%= new URLSearchParams({ user: filters.user || '', module: filters.module || '', from: filters.from || '', to: filters.to || '' }).toString() %>">Export to CSV</a>
  </div>

  <form method="GET" action="/admin/logs" class="form-grid four-col compact">
    <select name="user">
      <option value="">All users</option>
      <% users.forEach((option) => { %>
        <option value="<%= option.id %>" <%= String(filters.user || '') === String(option.id) ? 'selected' : '' %>><%= option.name %></option>
      <% }) %>
    </select>
    <input type="text" name="module" value="<%= filters.module || '' %>" placeholder="Module name">
    <input type="date" name="from" value="<%= filters.from || '' %>">
    <input type="date" name="to" value="<%= filters.to || '' %>">
    <select name="limit">
      <% [50, 75, 100].forEach((item) => { %>
        <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-primary">Apply</button>
  </form>
</section>

<section class="card stack">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>User</th>
          <th>Action</th>
          <th>Module</th>
          <th>Description</th>
          <th>IP</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length) { %>
          <% logs.forEach((log) => { %>
            <tr>
              <td><%= formatDate(log.created_at) %></td>
              <td>
                <strong><%= log.user_name %></strong>
                <div class="muted-copy"><%= log.user_email || '' %></div>
              </td>
              <td><span class="badge neutral"><%= log.action %></span></td>
              <td><%= log.module %></td>
              <td><%= log.description %></td>
              <td><%= log.ip_address || 'system' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="empty-state">No activity records found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
