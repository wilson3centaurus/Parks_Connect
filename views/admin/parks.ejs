<section class="page-grid two-column">
  <section class="card stack">
    <div class="section-header">
      <div>
        <h2>Create park</h2>
        <p>Add a park to the central platform.</p>
      </div>
    </div>
    <form method="POST" action="/admin/parks" class="form-grid two-col">
      <div class="field-group">
        <label for="parkName">Name</label>
        <input id="parkName" type="text" name="name" value="<%= formData.name || '' %>" required>
      </div>
      <div class="field-group">
        <label for="parkLocation">Location</label>
        <input id="parkLocation" type="text" name="location" value="<%= formData.location || '' %>" required>
      </div>
      <div class="field-group">
        <label for="parkRegion">Region</label>
        <input id="parkRegion" type="text" name="region" value="<%= formData.region || '' %>" required>
      </div>
      <div class="field-group">
        <label for="parkSize">Size (hectares)</label>
        <input id="parkSize" type="number" step="0.01" name="sizeHectares" value="<%= formData.sizeHectares || '' %>" required>
      </div>
      <div class="field-group">
        <label for="parkCapacity">Capacity</label>
        <input id="parkCapacity" type="number" name="capacity" value="<%= formData.capacity || '' %>" required>
      </div>
      <div class="field-group">
        <label for="parkStatus">Status</label>
        <select id="parkStatus" name="status" required>
          <% ['open', 'closed', 'restricted'].forEach((state) => { %>
            <option value="<%= state %>" <%= formData.status === state ? 'selected' : '' %>><%= state %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Create Park</button>
    </form>
  </section>

  <section class="card stack">
    <div class="section-header">
      <div>
        <h2>Park filters</h2>
        <p>Search and paginate all parks.</p>
      </div>
    </div>
    <form method="GET" action="/admin/parks" class="form-grid two-col compact">
      <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Search parks">
      <select name="status">
        <option value="">All status</option>
        <% ['open', 'closed', 'restricted'].forEach((state) => { %>
          <option value="<%= state %>" <%= filters.status === state ? 'selected' : '' %>><%= state %></option>
        <% }) %>
      </select>
      <select name="limit">
        <% [10, 25, 50].forEach((item) => { %>
          <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
        <% }) %>
      </select>
      <button type="submit" class="btn btn-secondary">Apply</button>
    </form>
  </section>
</section>

<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Park list</h2>
      <p>Current capacity and visitor snapshots.</p>
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Location</th>
          <th>Region</th>
          <th>Size</th>
          <th>Capacity</th>
          <th>Current Visitors</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (parks.length) { %>
          <% parks.forEach((park) => { %>
            <tr>
              <td><strong><%= park.name %></strong></td>
              <td><%= park.location %></td>
              <td><%= park.region %></td>
              <td><%= park.size_hectares %> ha</td>
              <td><%= park.capacity %></td>
              <td><%= park.current_visitors %></td>
              <td><span class="badge neutral"><%= park.status %></span></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" class="empty-state">No parks found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
