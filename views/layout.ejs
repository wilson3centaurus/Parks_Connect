<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ZimParks Platform</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <% const roleLabels = { admin: 'Administrator', ranger: 'Ranger', tourism_officer: 'Tourism Officer', analyst: 'Analyst' }; %>
  <% const linksByRole = {
    admin: [
      { href: '/dashboard', label: 'Dashboard', icon: 'DB' },
      { href: '/admin/users', label: 'Users', icon: 'US' },
      { href: '/admin/parks', label: 'Parks', icon: 'PK' },
      { href: '/wildlife', label: 'Wildlife', icon: 'WL' },
      { href: '/environment', label: 'Environment', icon: 'EN' },
      { href: '/infrastructure', label: 'Infrastructure', icon: 'IN' },
      { href: '/feedback/manage', label: 'Feedback', icon: 'FB' },
      { href: '/alerts', label: 'Alerts', icon: 'AL' },
      { href: '/analytics', label: 'Analytics', icon: 'AN' },
      { href: '/admin/logs', label: 'Logs', icon: 'LG' }
    ],
    ranger: [
      { href: '/dashboard', label: 'Dashboard', icon: 'DB' },
      { href: '/wildlife', label: 'Wildlife', icon: 'WL' },
      { href: '/environment', label: 'Environment', icon: 'EN' },
      { href: '/infrastructure', label: 'Infrastructure', icon: 'IN' },
      { href: '/alerts', label: 'Alerts', icon: 'AL' }
    ],
    tourism_officer: [
      { href: '/dashboard', label: 'Dashboard', icon: 'DB' },
      { href: '/feedback/manage', label: 'Feedback', icon: 'FB' },
      { href: '/analytics', label: 'Analytics', icon: 'AN' }
    ],
    analyst: [
      { href: '/dashboard', label: 'Dashboard', icon: 'DB' },
      { href: '/wildlife', label: 'Wildlife', icon: 'WL' },
      { href: '/environment', label: 'Environment', icon: 'EN' },
      { href: '/infrastructure', label: 'Infrastructure', icon: 'IN' },
      { href: '/feedback/manage', label: 'Feedback', icon: 'FB' },
      { href: '/alerts', label: 'Alerts', icon: 'AL' },
      { href: '/analytics', label: 'Analytics', icon: 'AN' }
    ]
  }; %>
  <% const sidebarLinks = linksByRole[user.role] || []; %>
  <% const todayLabel = new Date().toLocaleDateString('en-ZW', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }); %>

  <div class="app-shell">
    <button type="button" class="sidebar-backdrop" id="sidebar-backdrop" aria-label="Close navigation"></button>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-top">
        <div class="brand-block">
          <div class="brand-mark"><img src="/images/logo.png" alt="ZimParks logo"></div>
          <div>
            <div class="brand-title">ZimParks</div>
            <div class="brand-subtitle">Central operations</div>
          </div>
        </div>

        <div class="sidebar-panel sidebar-panel--highlight">
          <div class="muted-label">Current role</div>
          <div class="sidebar-user"><%= roleLabels[user.role] || user.role %></div>
          <div class="muted-copy">Navigation and workflows are filtered to the tools your role can use.</div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <% sidebarLinks.forEach((link) => { %>
          <a class="nav-link <%= currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'active' : '' %>" href="<%= link.href %>">
            <span class="nav-icon"><%= link.icon %></span>
            <span class="nav-copy">
              <span class="nav-label"><%= link.label %></span>
            </span>
          </a>
        <% }) %>
      </nav>

      <div class="sidebar-footer">
        <div class="sidebar-panel">
          <div class="muted-label">Unread notifications</div>
          <div class="sidebar-user"><%= unreadNotificationCount %></div>
          <div class="muted-copy">System alerts, reports, and workflow updates appear here first.</div>
        </div>

        <div class="sidebar-panel sidebar-panel--compact">
          <div class="muted-label">Signed in as</div>
          <div class="sidebar-user"><%= user.firstName %> <%= user.surname %></div>
          <div class="muted-copy"><%= user.email %></div>
        </div>
      </div>
    </aside>

    <div class="main-panel">
      <header class="topbar">
        <div class="topbar-left">
          <button type="button" class="menu-toggle" id="menu-toggle" aria-label="Toggle navigation">Menu</button>
          <div class="page-heading">
            <div class="page-kicker">ZimParks Platform</div>
            <h1 class="page-title"><%= title %></h1>
            <div class="page-subtitle">Conservation, tourism, and operational intelligence in one workspace.</div>
          </div>
        </div>

        <div class="topbar-right">
          <div class="topbar-chip-row">
            <span class="topbar-chip"><strong>Date</strong><span><%= todayLabel %></span></span>
            <span class="topbar-chip"><strong>Unread</strong><span><%= unreadNotificationCount %></span></span>
          </div>

          <details class="notification-menu">
            <summary class="notification-trigger" aria-label="Notifications">
              <span class="notification-bell">&#128276;</span>
              <span class="notification-label">Notifications</span>
              <% if (unreadNotificationCount > 0) { %>
                <span class="notification-count"><%= unreadNotificationCount %></span>
              <% } %>
            </summary>
            <div class="notification-panel">
              <% if (recentNotifications.length) { %>
                <% recentNotifications.forEach((notification) => { %>
                  <form method="POST" action="/notifications/<%= notification.id %>/read" class="notification-item">
                    <div>
                      <div class="notification-title"><%= notification.title %></div>
                      <div class="notification-message"><%= notification.message %></div>
                      <div class="notification-meta"><%= formatDate(notification.created_at) %></div>
                    </div>
                    <div class="notification-actions">
                      <% if (!notification.is_read) { %>
                        <button type="submit" class="link-button">Mark read</button>
                      <% } %>
                      <% if (notification.link) { %>
                        <a href="<%= notification.link %>" class="link-button">Open</a>
                      <% } %>
                    </div>
                  </form>
                <% }) %>
              <% } else { %>
                <div class="notification-empty">No notifications available.</div>
              <% } %>
            </div>
          </details>

          <div class="user-chip">
            <span><%= user.firstName %> <%= user.surname %></span>
            <small><%= roleLabels[user.role] || user.role %></small>
          </div>
          <a href="/logout" class="btn btn-secondary">Logout</a>
        </div>
      </header>

      <main class="page-content">
        <% if (successMessage) { %>
          <div class="notice success"><%= successMessage %></div>
        <% } %>
        <% if (errors && errors.length) { %>
          <div class="notice error">
            <ul>
              <% errors.forEach((error) => { %>
                <li><%= error.msg %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        <%- include(view) %>
      </main>
    </div>
  </div>

  <script>
    const toggleButton = document.getElementById('menu-toggle');
    const sidebar = document.getElementById('sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');

    function toggleSidebar(forceOpen) {
      if (!sidebar || !backdrop) {
        return;
      }

      const willOpen = typeof forceOpen === 'boolean' ? forceOpen : !sidebar.classList.contains('open');
      sidebar.classList.toggle('open', willOpen);
      backdrop.classList.toggle('visible', willOpen);
    }

    if (toggleButton) {
      toggleButton.addEventListener('click', () => toggleSidebar());
    }

    if (backdrop) {
      backdrop.addEventListener('click', () => toggleSidebar(false));
    }
  </script>
  <% if (includeChartJs) { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <% } %>
  <% (pageScripts || []).forEach((script) => { %>
    <script src="<%= script %>"></script>
  <% }) %>
</body>
</html>
