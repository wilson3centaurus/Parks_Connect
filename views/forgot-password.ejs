<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Forgot Password' %> | ZimParks Platform</title>
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <main class="auth-shell">
    <section class="auth-stage auth-stage--split">
      <aside class="auth-hero">
        <div class="hero-topbar">
          <div class="auth-brand">
            <div class="brand-mark"><img src="/images/logo.png" alt="ZimParks logo"></div>
            <div>
              <h1>Password reset</h1>
              <p>Secure account recovery from one page</p>
            </div>
          </div>
          <a href="/login" class="ghost-link">Back to login</a>
        </div>

        <div class="hero-panel hero-panel--editorial">
          <span class="hero-eyebrow">Credential recovery</span>
          <h2>Unlock reset only after the OTP has been verified.</h2>
          <p>The visual system matches the new brand direction while keeping the recovery flow strict, explicit, and easy to follow on desktop or mobile.</p>
        </div>

        <div class="hero-metric-grid hero-metric-grid--two">
          <div class="hero-metric">
            <span>Reset gate</span>
            <strong>Session</strong>
            <p>The server still rejects reset requests without the verified OTP session flag.</p>
          </div>
          <div class="hero-metric">
            <span>Expiry</span>
            <strong>10 min</strong>
            <p>Reset OTPs expire quickly and cannot be reused after completion.</p>
          </div>
        </div>

        <ol class="hero-steps">
          <li class="<%= otpSent ? 'complete' : 'active' %>">Enter account email and target password</li>
          <li class="<%= otpSent && !otpVerified ? 'active' : otpVerified ? 'complete' : '' %>">Verify the reset OTP</li>
          <li class="<%= otpVerified ? 'active' : '' %>">Submit the final password reset</li>
        </ol>

        <div class="hero-visual-card hero-visual-card--compact">
          <div class="visual-label-row">
            <span class="visual-label">Recovery controls</span>
            <span class="visual-status">Identity-first reset</span>
          </div>
          <div class="hero-list">
            <div class="hero-list-item">
              <strong>Admin key required</strong>
              <span>The recovery flow validates the admin key before the OTP can be issued.</span>
            </div>
            <div class="hero-list-item">
              <strong>Password policy enforced</strong>
              <span>The same server-side complexity rules apply during reset and registration.</span>
            </div>
          </div>
        </div>
      </aside>

      <section class="auth-card auth-card--form">
        <div class="auth-card-header">
          <div>
            <span class="auth-kicker">Credential Recovery</span>
            <h2>Reset your password</h2>
            <p>Send the reset OTP, verify it, and then submit the new password once the flow is unlocked.</p>
          </div>
          <div class="card-badge">Reset Protected</div>
        </div>

        <% if (successMessage) { %><div class="notice success"><%= successMessage %></div><% } %>
        <% if (errors && errors.length) { %>
          <div class="notice error">
            <ul>
              <% errors.forEach((error) => { %><li><%= error.msg %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form id="reset-form" method="POST" action="/forgot-password/reset" class="auth-form">
          <div class="field-grid two-col">
            <div class="field-group full-width">
              <label for="resetEmail">Email</label>
              <input id="resetEmail" type="email" name="email" value="<%= formData.email || '' %>" required>
            </div>
            <div class="field-group full-width">
              <label for="adminKey">Admin Key</label>
              <input id="adminKey" type="password" name="adminKey" value="<%= formData.adminKey || '' %>" required>
            </div>
            <div class="field-group">
              <label for="newPassword">New Password</label>
              <input id="newPassword" type="password" name="password" value="<%= formData.password || '' %>" required>
              <small id="resetPasswordHelp" class="field-note">Must contain 8+ characters, one uppercase letter, one number, and one special character.</small>
            </div>
            <div class="field-group">
              <label for="confirmNewPassword">Re-enter New Password</label>
              <input id="confirmNewPassword" type="password" name="confirmPassword" value="<%= formData.confirmPassword || '' %>" required>
            </div>
          </div>

          <div class="auth-form-actions">
            <button type="submit" formaction="/forgot-password/send-otp" formmethod="POST" formnovalidate class="btn btn-secondary full-width">
              <%= otpSent ? 'Resend Reset OTP' : 'Send Reset OTP' %>
            </button>
          </div>
        </form>

        <form id="verify-otp-form" method="POST" action="/forgot-password/verify-otp">
          <input type="hidden" name="email" value="<%= formData.email || '' %>">
          <% if (otpSent) { %>
            <section id="otp-section">
              <h3>Reset OTP Verification</h3>
              <input type="text" name="otp" placeholder="Enter OTP" maxlength="6" pattern="\d{6}" autocomplete="one-time-code">
              <button type="submit" form="verify-otp-form">Verify OTP</button>
              <p class="<%= otpError ? 'error' : 'success' %>"><%= otpMessage || '' %></p>
            </section>
          <% } %>
        </form>
        <button type="submit" form="reset-form" <%= otpVerified ? '' : 'disabled' %>>Reset Password</button>

        <div class="card-divider"></div>

        <div class="auth-links">
          <a href="/login">Back to login</a>
        </div>
      </section>
    </section>
  </main>

  <script>
    const passwordInput = document.getElementById('newPassword');
    const confirmPasswordInput = document.getElementById('confirmNewPassword');
    const resetForm = document.getElementById('reset-form');
    const passwordHelp = document.getElementById('resetPasswordHelp');
    const passwordPattern = /^(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/;

    function validatePassword() {
      const passwordValid = passwordPattern.test(passwordInput.value || '');
      const passwordsMatch = !confirmPasswordInput.value || passwordInput.value === confirmPasswordInput.value;
      if (!passwordValid) {
        passwordHelp.textContent = 'Password does not meet the required rule.';
        passwordHelp.className = 'field-note error';
        return false;
      }
      if (!passwordsMatch) {
        passwordHelp.textContent = 'Passwords must match.';
        passwordHelp.className = 'field-note error';
        return false;
      }
      passwordHelp.textContent = 'Password rule satisfied.';
      passwordHelp.className = 'field-note success';
      return true;
    }

    passwordInput.addEventListener('input', validatePassword);
    confirmPasswordInput.addEventListener('input', validatePassword);
    resetForm.addEventListener('submit', (event) => {
      if (!validatePassword()) {
        event.preventDefault();
      }
    });
  </script>
</body>
</html>
