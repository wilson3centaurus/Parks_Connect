<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Submit Feedback' %> | ZimParks Platform</title>
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <main class="auth-shell">
    <section class="auth-stage auth-stage--split">
      <aside class="auth-hero">
        <div class="hero-topbar">
          <div class="auth-brand">
            <div class="brand-mark"><img src="/images/logo.png" alt="ZimParks logo"></div>
            <div>
              <h1>Public feedback</h1>
              <p>Visitor voice for better park experiences</p>
            </div>
          </div>
          <a href="/login" class="ghost-link">Staff login</a>
        </div>

        <div class="hero-panel hero-panel--editorial">
          <span class="hero-eyebrow">Visitor voice</span>
          <h2>Turn experience on the ground into action for the operations team.</h2>
          <p>The page follows the same editorial rhythm: large message, clear supporting blocks, and a clean action surface for fast submission.</p>
        </div>

        <div class="hero-metric-grid hero-metric-grid--two">
          <div class="hero-metric">
            <span>Access</span>
            <strong>Open</strong>
            <p>No login is required for the public channel.</p>
          </div>
          <div class="hero-metric">
            <span>Routing</span>
            <strong>Tracked</strong>
            <p>Ratings and categories feed operations review and analytics.</p>
          </div>
        </div>

        <div class="visual-pill-row">
          <span class="hero-chip">Facilities</span>
          <span class="hero-chip">Wildlife</span>
          <span class="hero-chip">Safety</span>
          <span class="hero-chip">Staff</span>
        </div>

        <div class="hero-list">
          <div class="hero-list-item">
            <strong>Structured routing</strong>
            <span>Feedback is categorized to the correct tourism and administrative teams.</span>
          </div>
          <div class="hero-list-item">
            <strong>Service improvement</strong>
            <span>Messages help parks improve visitor safety, facilities, and service standards.</span>
          </div>
        </div>
      </aside>

      <section class="auth-card auth-card--form">
        <div class="auth-card-header">
          <div>
            <span class="auth-kicker">Public Form</span>
            <h2>Submit feedback</h2>
            <p>Select the park, rate the experience, and explain what worked or what needs attention.</p>
          </div>
          <div class="card-badge">No Login Required</div>
        </div>

        <% if (successMessage) { %><div class="notice success"><%= successMessage %></div><% } %>
        <% if (errors && errors.length) { %>
          <div class="notice error">
            <ul>
              <% errors.forEach((error) => { %><li><%= error.msg %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form method="POST" action="/feedback/submit" class="auth-form">
          <div class="field-grid two-col">
            <div class="field-group full-width">
              <label for="parkId">Park</label>
              <select id="parkId" name="parkId" required>
                <option value="">Select park</option>
                <% parks.forEach((park) => { %>
                  <option value="<%= park.id %>" <%= String(formData.parkId || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field-group">
              <label for="visitorName">Visitor Name</label>
              <input id="visitorName" type="text" name="visitorName" value="<%= formData.visitorName || '' %>" required>
            </div>
            <div class="field-group">
              <label for="visitorEmail">Visitor Email</label>
              <input id="visitorEmail" type="email" name="visitorEmail" value="<%= formData.visitorEmail || '' %>" required>
            </div>
            <div class="field-group">
              <label for="visitorPhone">Visitor Phone</label>
              <input id="visitorPhone" type="text" name="visitorPhone" value="<%= formData.visitorPhone || '' %>">
            </div>
            <div class="field-group">
              <label for="channel">Channel</label>
              <select id="channel" name="channel" required>
                <% ['web', 'sms', 'mobile_app'].forEach((channel) => { %>
                  <option value="<%= channel %>" <%= formData.channel === channel ? 'selected' : '' %>><%= channel %></option>
                <% }) %>
              </select>
            </div>
            <div class="field-group">
              <label for="rating">Rating</label>
              <input id="rating" type="number" min="1" max="5" name="rating" value="<%= formData.rating || '' %>" required>
            </div>
            <div class="field-group">
              <label for="category">Category</label>
              <select id="category" name="category" required>
                <% ['facilities', 'wildlife', 'staff', 'safety', 'general'].forEach((category) => { %>
                  <option value="<%= category %>" <%= formData.category === category ? 'selected' : '' %>><%= category %></option>
                <% }) %>
              </select>
            </div>
            <div class="field-group full-width">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required><%= formData.message || '' %></textarea>
            </div>
          </div>
          <button type="submit" class="btn btn-primary full-width">Submit Feedback</button>
        </form>

        <div class="card-divider"></div>

        <div class="auth-links">
          <a href="/login">Staff login</a>
        </div>
      </section>
    </section>
  </main>
</body>
</html>
