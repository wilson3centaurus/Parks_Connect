<section class="card stack">
  <div class="section-header"><div><h2>Record environmental reading</h2><p>Capture field measurements with severity classification.</p></div></div>
  <form method="POST" action="/environment" class="form-grid two-col">
    <div class="field-group">
      <label for="parkId">Park</label>
      <select id="parkId" name="parkId" required>
        <option value="">Select park</option>
        <% parks.forEach((park) => { %>
          <option value="<%= park.id %>" <%= String(formData.parkId || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="field-group">
      <label for="readingType">Reading Type</label>
      <select id="readingType" name="readingType" required>
        <% ['temperature', 'rainfall', 'humidity', 'water_level', 'drought_index', 'air_quality'].forEach((type) => { %>
          <option value="<%= type %>" <%= formData.readingType === type ? 'selected' : '' %>><%= type %></option>
        <% }) %>
      </select>
    </div>
    <div class="field-group">
      <label for="value">Value</label>
      <input id="value" type="number" step="0.01" name="value" value="<%= formData.value || '' %>" required>
    </div>
    <div class="field-group">
      <label for="unit">Unit</label>
      <input id="unit" type="text" name="unit" value="<%= formData.unit || '' %>" required>
    </div>
    <div class="field-group">
      <label for="readingDate">Reading Date</label>
      <input id="readingDate" type="datetime-local" name="readingDate" value="<%= formData.readingDate || '' %>" required>
    </div>
    <div class="field-group">
      <label for="status">Status</label>
      <select id="status" name="status" required>
        <% ['normal', 'warning', 'critical'].forEach((state) => { %>
          <option value="<%= state %>" <%= formData.status === state ? 'selected' : '' %>><%= state %></option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Save reading</button>
  </form>
</section>
