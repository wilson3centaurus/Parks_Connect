<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Environmental readings</h2>
      <p>Track current field readings and risk levels.</p>
    </div>
    <% if (user.role !== 'analyst') { %><a href="/environment/new" class="btn btn-primary">Add reading</a><% } %>
  </div>
  <form method="GET" action="/environment" class="form-grid four-col compact">
    <select name="parkId">
      <option value="">All parks</option>
      <% parks.forEach((park) => { %>
        <option value="<%= park.id %>" <%= String(filters.parkId || '') === String(park.id) ? 'selected' : '' %>><%= park.name %></option>
      <% }) %>
    </select>
    <select name="readingType">
      <option value="">All types</option>
      <% ['temperature', 'rainfall', 'humidity', 'water_level', 'drought_index', 'air_quality'].forEach((type) => { %>
        <option value="<%= type %>" <%= filters.readingType === type ? 'selected' : '' %>><%= type %></option>
      <% }) %>
    </select>
    <select name="status">
      <option value="">All status</option>
      <% ['normal', 'warning', 'critical'].forEach((state) => { %>
        <option value="<%= state %>" <%= filters.status === state ? 'selected' : '' %>><%= state %></option>
      <% }) %>
    </select>
    <select name="limit">
      <% [10, 25, 50].forEach((item) => { %>
        <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary">Apply</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Park</th>
          <th>Type</th>
          <th>Value</th>
          <th>Status</th>
          <th>Recorded By</th>
        </tr>
      </thead>
      <tbody>
        <% if (readings.length) { %>
          <% readings.forEach((item) => { %>
            <tr>
              <td><%= formatDate(item.reading_date) %></td>
              <td><%= item.park_name %></td>
              <td><%= item.reading_type %></td>
              <td><%= item.value %> <%= item.unit %></td>
              <td><span class="badge <%= item.status === 'critical' ? 'error' : item.status === 'warning' ? 'warning' : 'success' %>"><%= item.status %></span></td>
              <td><%= item.recorded_by_name %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="empty-state">No environmental readings found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
