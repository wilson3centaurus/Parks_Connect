<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Create Account' %> | ZimParks Platform</title>
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <main class="auth-shell">
    <section class="auth-stage auth-stage--split">
      <aside class="auth-hero">
        <div class="hero-topbar">
          <div class="auth-brand">
            <div class="brand-mark"><img src="/images/logo.png" alt="ZimParks logo"></div>
            <div>
              <h1>Create account</h1>
              <p>Single-page onboarding with OTP verification</p>
            </div>
          </div>
          <a href="/login" class="ghost-link">Back to login</a>
        </div>

        <div class="hero-panel hero-panel--editorial">
          <span class="hero-eyebrow">Controlled onboarding</span>
          <h2>Provision access through a verified operational identity.</h2>
          <p>The layout keeps the same editorial structure: bold headline, supporting panels, and a high-contrast form surface tuned for staff registration.</p>
        </div>

        <div class="hero-metric-grid hero-metric-grid--two">
          <div class="hero-metric">
            <span>OTP</span>
            <strong>10 min</strong>
            <p>Six digits, single-use, purpose-scoped, and server enforced.</p>
          </div>
          <div class="hero-metric">
            <span>Roles</span>
            <strong>Scoped</strong>
            <p>Internal roles require the admin registration key before access is created.</p>
          </div>
        </div>

        <ol class="hero-steps">
          <li class="<%= otpSent ? 'complete' : 'active' %>">Enter account details and send OTP</li>
          <li class="<%= otpSent ? 'active' : '' %>">Enter OTP and register account</li>
        </ol>

        <div class="hero-visual-card hero-visual-card--compact">
          <div class="visual-label-row">
            <span class="visual-label">Access controls</span>
            <span class="visual-status">Server-validated flow</span>
          </div>
          <div class="visual-pill-row">
            <span class="hero-chip">Password policy</span>
            <span class="hero-chip">Role-based access</span>
            <span class="hero-chip">Admin key gate</span>
            <span class="hero-chip">Email OTP</span>
          </div>
          <div class="hero-list">
            <div class="hero-list-item">
              <strong>Password policy</strong>
              <span>At least 8 characters, one uppercase letter, one number, and one special character.</span>
            </div>
            <div class="hero-list-item">
              <strong>Registration control</strong>
              <span>OTP is verified and the account is registered in a single step. A wrong OTP blocks registration.</span>
            </div>
          </div>
        </div>
      </aside>

      <section class="auth-card auth-card--form">
        <div class="auth-card-header">
          <div>
            <span class="auth-kicker">New Account</span>
            <h2>Registration form</h2>
            <p>Complete the form, send the OTP, verify it, and then submit the final account request.</p>
          </div>
          <div class="card-badge">OTP Locked</div>
        </div>

        <% if (errors && errors.length) { %>
          <div class="notice error">
            <ul>
              <% errors.forEach((error) => { %><li><%= error.msg %></li><% }) %>
            </ul>
          </div>
        <% } %>

        <form id="register-form" method="POST" action="/create-account/verify-and-register" class="auth-form">
          <div class="field-grid two-col">
            <div class="field-group">
              <label for="firstName">First Name</label>
              <input id="firstName" type="text" name="firstName" value="<%= formData.firstName || '' %>" maxlength="50" pattern="[A-Za-z\s\-']+" required>
            </div>
            <div class="field-group">
              <label for="surname">Surname</label>
              <input id="surname" type="text" name="surname" value="<%= formData.surname || '' %>" maxlength="50" pattern="[A-Za-z\s\-']+" required>
            </div>
            <div class="field-group">
              <label for="email">Email</label>
              <input id="email" type="email" name="email" value="<%= formData.email || '' %>" required>
            </div>
            <div class="field-group">
              <label for="phone">Phone</label>
              <input id="phone" type="tel" name="phone" value="<%= formData.phone || '' %>" placeholder="0771234567 or +263771234567" pattern="(\+263|0)\d{9}" required>
              <small id="phoneHelp" class="field-note">Zimbabwean number: 0771234567 or +263771234567</small>
            </div>
            <div class="field-group">
              <label for="role">Role</label>
              <select id="role" name="role" required>
                <% ['admin', 'ranger', 'tourism_officer', 'analyst', 'public'].forEach((role) => { %>
                  <option value="<%= role %>" <%= formData.role === role ? 'selected' : '' %>><%= role %></option>
                <% }) %>
              </select>
            </div>
            <div class="field-group">
              <label for="adminRegistrationKey">Admin Registration Key</label>
              <input id="adminRegistrationKey" type="password" name="adminRegistrationKey" value="" placeholder="Required for internal staff roles">
            </div>
            <div class="field-group">
              <label for="password">Password</label>
              <input id="password" type="password" name="password" value="<%= formData.password || '' %>" required>
              <small id="passwordHelp" class="field-note">Must contain 8+ characters, one uppercase letter, one number, and one special character.</small>
            </div>
            <div class="field-group">
              <label for="confirmPassword">Confirm Password</label>
              <input id="confirmPassword" type="password" name="confirmPassword" value="<%= formData.confirmPassword || '' %>" required>
            </div>
          </div>

          <% if (otpSent) { %>
            <div class="field-group otp-field">
              <label for="otp">OTP Code</label>
              <input id="otp" type="text" name="otp" placeholder="Enter 6-digit OTP" maxlength="6" pattern="\d{6}" autocomplete="one-time-code">
            </div>
            <% if (otpMessage) { %>
              <p class="field-note <%= otpError ? 'error' : 'success' %>"><%= otpMessage %></p>
            <% } %>
          <% } %>

          <div class="auth-form-actions">
            <button type="submit" formaction="/create-account/send-otp" formmethod="POST" formnovalidate class="btn btn-secondary full-width">
              <%= otpSent ? 'Resend OTP' : 'Send OTP' %>
            </button>
            <% if (otpSent) { %>
              <button type="submit" class="btn btn-primary full-width">Verify &amp; Register</button>
            <% } %>
          </div>
        </form>

        <div class="card-divider"></div>

        <div class="auth-links">
          <a href="/login">Back to login</a>
        </div>
      </section>
    </section>
  </main>

  <script>
    const passwordInput = document.getElementById('password');
    const confirmPasswordInput = document.getElementById('confirmPassword');
    const phoneInput = document.getElementById('phone');
    const registerForm = document.getElementById('register-form');
    const passwordHelp = document.getElementById('passwordHelp');
    const phoneHelp = document.getElementById('phoneHelp');
    const passwordPattern = /^(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}$/;
    const phonePattern = /^(\+263|0)\d{9}$/;

    let submittedAction = null;
    document.querySelectorAll('#register-form button[type="submit"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        submittedAction = btn.getAttribute('formaction') || 'verify-and-register';
      });
    });

    function validatePassword() {
      const passwordValid = passwordPattern.test(passwordInput.value || '');
      const passwordsMatch = !confirmPasswordInput.value || passwordInput.value === confirmPasswordInput.value;
      if (!passwordValid) {
        passwordHelp.textContent = 'Password does not meet the required rule.';
        passwordHelp.className = 'field-note error';
        return false;
      }
      if (!passwordsMatch) {
        passwordHelp.textContent = 'Passwords must match.';
        passwordHelp.className = 'field-note error';
        return false;
      }
      passwordHelp.textContent = 'Password rule satisfied.';
      passwordHelp.className = 'field-note success';
      return true;
    }

    function validatePhone() {
      const val = phoneInput.value.trim();
      if (!val) {
        phoneHelp.textContent = 'Phone number is required.';
        phoneHelp.className = 'field-note error';
        return false;
      }
      if (!phonePattern.test(val)) {
        phoneHelp.textContent = 'Invalid format. Use 0771234567 or +263771234567.';
        phoneHelp.className = 'field-note error';
        return false;
      }
      phoneHelp.textContent = 'Phone number looks good.';
      phoneHelp.className = 'field-note success';
      return true;
    }

    passwordInput.addEventListener('input', validatePassword);
    confirmPasswordInput.addEventListener('input', validatePassword);
    phoneInput.addEventListener('input', validatePhone);

    registerForm.addEventListener('submit', (event) => {
      const phoneOk = validatePhone();
      const passwordOk = validatePassword();
      if (!phoneOk || !passwordOk) {
        event.preventDefault();
      }
    });
  </script>
</body>
</html>
