<section class="card stack">
  <div class="section-header">
    <div>
      <h2>Alerts</h2>
      <p>Track active, acknowledged, and resolved alert records.</p>
    </div>
    <% if (user.role !== 'analyst') { %><a href="/alerts/create" class="btn btn-primary">Create alert</a><% } %>
  </div>
  <form method="GET" action="/alerts" class="form-grid four-col compact">
    <select name="status">
      <option value="">All status</option>
      <% ['active', 'acknowledged', 'resolved'].forEach((state) => { %>
        <option value="<%= state %>" <%= filters.status === state ? 'selected' : '' %>><%= state %></option>
      <% }) %>
    </select>
    <select name="severity">
      <option value="">All severity</option>
      <% ['low', 'medium', 'high', 'critical'].forEach((state) => { %>
        <option value="<%= state %>" <%= filters.severity === state ? 'selected' : '' %>><%= state %></option>
      <% }) %>
    </select>
    <select name="type">
      <option value="">All types</option>
      <% ['drought', 'infrastructure_failure', 'security_incident', 'capacity_threshold', 'wildlife_emergency', 'weather'].forEach((item) => { %>
        <option value="<%= item %>" <%= filters.type === item ? 'selected' : '' %>><%= item %></option>
      <% }) %>
    </select>
    <select name="limit">
      <% [10, 25, 50].forEach((item) => { %>
        <option value="<%= item %>" <%= pagination.limit === item ? 'selected' : '' %>><%= item %> per page</option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-secondary">Apply</button>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Created</th>
          <th>Park</th>
          <th>Title</th>
          <th>Type</th>
          <th>Severity</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (alerts.length) { %>
          <% alerts.forEach((alert) => { %>
            <tr>
              <td><%= formatDate(alert.created_at) %></td>
              <td><%= alert.park_name %></td>
              <td><strong><%= alert.title %></strong><div class="muted-copy"><%= alert.description %></div></td>
              <td><%= alert.type %></td>
              <td><span class="badge <%= alert.severity === 'critical' ? 'error' : alert.severity === 'high' ? 'warning' : 'neutral' %>"><%= alert.severity %></span></td>
              <td><span class="badge neutral"><%= alert.status %></span></td>
              <td>
                <div class="action-row">
                  <% if (user.role !== 'analyst' && alert.status === 'active') { %>
                    <form method="POST" action="/alerts/<%= alert.id %>/acknowledge"><button type="submit" class="btn btn-secondary">Acknowledge</button></form>
                  <% } %>
                  <% if (user.role === 'admin' && alert.status !== 'resolved') { %>
                    <form method="POST" action="/alerts/<%= alert.id %>/resolve"><button type="submit" class="btn btn-danger">Resolve</button></form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="7" class="empty-state">No alerts found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if (pagination.prevUrl) { %><a href="<%= pagination.prevUrl %>" class="btn btn-secondary">Previous</a><% } %>
    <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
    <% if (pagination.nextUrl) { %><a href="<%= pagination.nextUrl %>" class="btn btn-secondary">Next</a><% } %>
  </div>
</section>
