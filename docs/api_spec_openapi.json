{
  "openapi": "3.0.3",
  "info": {
    "title": "Parks Connect API",
    "version": "1.0.0",
    "description": "REST API for Parks Connect covering auth, visitor logs, environmental logs, feedback, notifications, and analytics."
  },
  "servers": [
    { "url": "http://localhost:4000", "description": "Local dev" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "VisitorLog": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "visit_date": { "type": "string", "format": "date" },
          "visitors_count": { "type": "integer" },
          "occupancy_rate": { "type": "number" },
          "facility_feedback": { "type": "string" }
        }
      },
      "EnvironmentLog": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string" },
          "location_lat": { "type": "number" },
          "location_lng": { "type": "number" }
        }
      },
      "Feedback": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "submitted_by": { "type": "string" },
          "type": { "type": "string", "enum": ["tourist", "tourism_operator"] },
          "rating": { "type": "number" },
          "comments": { "type": "string" },
          "gps_lat": { "type": "number" },
          "gps_lng": { "type": "number" },
          "status": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string" },
          "role": { "type": "string", "enum": ["authority_admin", "environment_officer", "tourism_operator", "tourist"] }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": { "summary": "Health check", "responses": { "200": { "description": "OK" } } }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT issued"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Register user",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } }
        },
        "responses": { "201": { "description": "User created" } }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Current user",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "User" } }
      }
    },
    "/api/visitor-logs": {
      "get": {
        "summary": "List visitor logs",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Array of logs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/VisitorLog" } } } } } }
      },
      "post": {
        "summary": "Create visitor log",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VisitorLog" } } }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/environmental-logs": {
      "get": {
        "summary": "List environmental logs",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Array", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/EnvironmentLog" } } } } } }
      },
      "post": {
        "summary": "Create environmental log",
        "security": [{ "BearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EnvironmentLog" } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/feedback": {
      "get": {
        "summary": "List feedback",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Array", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Feedback" } } } } } }
      },
      "post": {
        "summary": "Submit feedback (tourist/tourism operator)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Feedback" } },
            "multipart/form-data": { "schema": { "$ref": "#/components/schemas/Feedback" } }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/feedback/{id}/status": {
      "put": {
        "summary": "Update feedback status",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/notifications": {
      "get": {
        "summary": "List notifications",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Array" } }
      }
    },
    "/api/notifications/{id}/resolve": {
      "put": {
        "summary": "Resolve notification",
        "security": [{ "BearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Resolved" } }
      }
    },
    "/api/analytics/summary": {
      "get": {
        "summary": "Analytics summary",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "KPIs and charts" } }
      }
    }
  }
}

